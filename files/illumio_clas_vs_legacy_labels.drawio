<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram id="page1" name="CLAS vs Legacy and Label Model">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="0"
                  pageScale="1" pageWidth="1654" pageHeight="1169"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="10" value="CLAS Mode vs Legacy Mode  +  Illumio Label Model
Architectural comparison and Kubernetes-to-Illumio label mapping reference" style="rounded=1;arcSize=3;fillColor=#E0F5EC;strokeColor=#0D7A5F;fontColor=#064F3C;fontStyle=1;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1600" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="CLAS Mode (Recommended — Illumio Core for Kubernetes 5.0.0+)" style="swimlane;startSize=35;fillColor=#E0F5EC;strokeColor=#0D7A5F;fontColor=#064F3C;fontStyle=1;fontSize=13;fontFamily=Arial;strokeWidth=2;rounded=1;arcSize=2;" vertex="1" parent="1">
          <mxGeometry x="0" y="65" width="770" height="580" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="🖥️ PCE
External control plane
Policy source of truth" style="rounded=1;arcSize=5;fillColor=#EDE9FD;strokeColor=#5B4CC4;fontColor=#3B2E8A;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="11">
          <mxGeometry x="15" y="50" width="200" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="⚡ Kubelink + CLAS Cache
Cluster-local policy store
Kubelink writes compiled policy
C-VEN reads from local cache
(no direct PCE contact needed)" style="rounded=1;arcSize=5;fillColor=#E0F5EC;strokeColor=#0D7A5F;fontColor=#064F3C;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="11">
          <mxGeometry x="235" y="50" width="270" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="14" value="policy
push" style="edgeStyle=orthogonalEdgeStyle;dashed=1;dashPattern=8 4;strokeWidth=1.5;strokeColor=#5B4CC4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#5B4CC4;fontStyle=1;rounded=1;" edge="1" source="12" target="13" parent="11">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="15" value="🛡️ C-VEN
Reads policy from
local CLAS cache
(not from PCE)" style="rounded=1;arcSize=5;fillColor=#E3EFFC;strokeColor=#1A66B5;fontColor=#0C3F75;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="11">
          <mxGeometry x="235" y="210" width="180" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="16" value="local
policy" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;strokeColor=#0D7A5F;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#0D7A5F;fontStyle=1;rounded=1;" edge="1" source="13" target="15" parent="11">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="17" value="💾 Storage Pod
Per-node policy cache
Flow telemetry buffer" style="rounded=1;arcSize=5;fillColor=#FEF0DA;strokeColor=#9B5E0C;fontColor=#6B3D06;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="11">
          <mxGeometry x="435" y="210" width="180" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="18" value="read
cache" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#1A66B5;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#1A66B5;fontStyle=1;rounded=1;" edge="1" source="15" target="17" parent="11">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="19" value="✅ PCE Outage — CLAS Behavior

Policy served from local CLAS cache.
Enforcement continues uninterrupted.
New policy changes queue until PCE reconnects.
Zero enforcement gap during outage." style="rounded=1;arcSize=5;fillColor=#E4F5E2;strokeColor=#2E7D32;fontColor=#1B4D1D;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="11">
          <mxGeometry x="15" y="360" width="735" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="20" value="Migration:  clusterMode: migrateLegacyToClas  in Helm values — one cluster at a time" style="rounded=1;arcSize=5;fillColor=#E0F5EC;strokeColor=#0D7A5F;fontColor=#064F3C;fontSize=10;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="11">
          <mxGeometry x="15" y="490" width="735" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="Legacy Mode (Pre-CLAS — C-VEN contacts PCE directly)" style="swimlane;startSize=35;fillColor=#F5F2EC;strokeColor=#6B6860;fontColor=#3F3E3A;fontStyle=1;fontSize=13;fontFamily=Arial;strokeWidth=2;rounded=1;arcSize=2;" vertex="1" parent="1">
          <mxGeometry x="830" y="65" width="770" height="580" as="geometry"/>
        </mxCell>
        <mxCell id="22" value="🖥️ PCE
External control plane
Direct C-VEN contact" style="rounded=1;arcSize=5;fillColor=#EDE9FD;strokeColor=#5B4CC4;fontColor=#3B2E8A;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="21">
          <mxGeometry x="15" y="50" width="200" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="23" value="🛡️ C-VEN
Contacts PCE API directly
for every policy update

⚠️ PCE 406 = policy failure
⚠️ Outage = degraded mode" style="rounded=1;arcSize=5;fillColor=#E3EFFC;strokeColor=#1A66B5;fontColor=#0C3F75;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="21">
          <mxGeometry x="235" y="50" width="260" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="24" value="direct
API call" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#5B4CC4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#5B4CC4;fontStyle=1;rounded=1;" edge="1" source="22" target="23" parent="21">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="25" value="💾 Storage Pod
Short-term cache only
No local CLAS store
Limited resilience" style="rounded=1;arcSize=5;fillColor=#FEF0DA;strokeColor=#9B5E0C;fontColor=#6B3D06;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="21">
          <mxGeometry x="235" y="240" width="260" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="26" value="cache
write" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#1A66B5;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#1A66B5;fontStyle=1;rounded=1;" edge="1" source="23" target="25" parent="21">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="27" value="🔴 PCE Outage — Legacy Behavior

C-VEN enters degraded mode.
Holds last known policy state.
New policy changes cannot reach C-VEN.
PCE 406 throttling = heartbeat AND policy failures." style="rounded=1;arcSize=5;fillColor=#FDE8E0;strokeColor=#C14B1A;fontColor=#8A2E0A;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="21">
          <mxGeometry x="15" y="360" width="735" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="28" value="Root cause of April 2026 incident: Storage Pod etcd auth failure caused 406 throttling on PCE
This caused stale C-VEN heartbeats, no flow telemetry, and apparent policy failures across all clusters" style="rounded=1;arcSize=5;fillColor=#FDE8E0;strokeColor=#C14B1A;fontColor=#8A2E0A;fontSize=10;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="21">
          <mxGeometry x="15" y="490" width="735" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="29" value="ILLUMIO LABEL MODEL — Kubernetes Labels → Illumio Policy Dimensions via Kubelink label_mapping configuration" style="rounded=1;arcSize=3;fillColor=#E3EFFC;strokeColor=#1A66B5;fontColor=#0C3F75;fontStyle=1;fontSize=13;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="0" y="660" width="1600" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="30" value="Kubernetes Namespace Labels

illumio-app: A-APP-256708
illumio-env: prod
illumio-loc: datacenter

→ Applied before deploying pods
→ Kubelink reads these on pod start" style="rounded=1;arcSize=5;fillColor=#E3EFFC;strokeColor=#1A66B5;fontColor=#0C3F75;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="10" y="730" width="280" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="Kubernetes Pod Labels
(Deployment spec)

illumio-role: web

→ Set in Deployment template
→ Each role maps separately" style="rounded=1;arcSize=5;fillColor=#E3EFFC;strokeColor=#1A66B5;fontColor=#0C3F75;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="10" y="945" width="280" height="155" as="geometry"/>
        </mxCell>
        <mxCell id="32" value="⚡ Kubelink
label_mapping config
(illumio-values.yaml)

app:   illumio-app
env:   illumio-env
role:  illumio-role
loc:   illumio-loc" style="rounded=1;arcSize=5;fillColor=#E0F5EC;strokeColor=#0D7A5F;fontColor=#064F3C;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="360" y="730" width="300" height="370" as="geometry"/>
        </mxCell>
        <mxCell id="33" value="reads
namespace labels" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#1A66B5;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#1A66B5;fontStyle=1;rounded=1;" edge="1" source="30" target="32" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="34" value="reads
pod labels" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#1A66B5;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#1A66B5;fontStyle=1;rounded=1;" edge="1" source="31" target="32" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="35" value="Illumio Label Model

App  =  A-APP-256708
Env  =  prod
Role =  web
Loc  =  datacenter

→ Written to PCE workload record
→ Used to match policy rules" style="rounded=1;arcSize=5;fillColor=#EDE9FD;strokeColor=#5B4CC4;fontColor=#3B2E8A;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="740" y="730" width="300" height="370" as="geometry"/>
        </mxCell>
        <mxCell id="36" value="syncs label
dimensions to PCE" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;strokeColor=#0D7A5F;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#0D7A5F;fontStyle=1;rounded=1;" edge="1" source="32" target="35" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="37" value="Policy Rule Example

Source:       Role=web, Env=prod
Destination:  Role=db, App=A-APP-256708
Service:      TCP port 1433
Action:       Allow

→ PCE compiles to iptables ACCEPT rule
→ Missing this rule = SQL Server blocked!" style="rounded=1;arcSize=5;fillColor=#E4F5E2;strokeColor=#2E7D32;fontColor=#1B4D1D;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="1110" y="730" width="330" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="38" value="policy uses
these labels" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#5B4CC4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#5B4CC4;fontStyle=1;rounded=1;" edge="1" source="35" target="37" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="39" value="⚠️  If any label is missing → workload registers as IP-only in PCE → no policy match → pd=3 Unknown → BLOCKED in Full enforcement
    App ID format must be A-APP-&lt;numeric-id&gt; (e.g., A-APP-256708) — wrong format means the policy rule will never match" style="rounded=1;arcSize=3;fillColor=#FDE8E0;strokeColor=#C14B1A;fontColor=#8A2E0A;fontSize=11;fontFamily=Arial;align=left;verticalAlign=middle;whiteSpace=wrap;spacingLeft=8;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="0" y="1115" width="1600" height="60" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
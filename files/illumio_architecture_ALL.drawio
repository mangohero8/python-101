  <diagram id="page2" name="Policy Flow Path">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="0"
                  pageScale="1" pageWidth="1654" pageHeight="1169"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="10" value="Policy Flow: Rule Creation → iptables Enforcement
Step-by-step path from PCE console to iptables chains on the worker node" style="rounded=1;arcSize=3;fillColor=#EDE9FD;strokeColor=#5B4CC4;fontColor=#3B2E8A;fontStyle=1;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1600" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="&lt;b&gt;STEP 1&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Rule Written&lt;/b&gt;&lt;br/&gt;Admin creates allow/deny rule
in PCE console or via REST API.
Rule is in Draft state." style="rounded=1;arcSize=8;fillColor=#EDE9FD;strokeColor=#5B4CC4;fontColor=#3B2E8A;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;html=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="&lt;b&gt;STEP 2&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Provisioned&lt;/b&gt;&lt;br/&gt;Draft → Active state.
PCE compiles a per-workload
ruleset from all active rules." style="rounded=1;arcSize=8;fillColor=#EDE9FD;strokeColor=#5B4CC4;fontColor=#3B2E8A;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;html=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="250" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;strokeColor=#5B4CC4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#5B4CC4;fontStyle=1;rounded=1;" edge="1" source="11" target="12" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="14" value="&lt;b&gt;STEP 3&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Kubelink Sync&lt;/b&gt;&lt;br/&gt;Kubelink maps Kubernetes
labels to Illumio label
dimensions (Role/App/Env/Loc)." style="rounded=1;arcSize=8;fillColor=#E0F5EC;strokeColor=#0D7A5F;fontColor=#064F3C;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;html=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="420" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="15" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;strokeColor=#0D7A5F;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#0D7A5F;fontStyle=1;rounded=1;" edge="1" source="12" target="14" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="16" value="&lt;b&gt;STEP 4&lt;/b&gt;&lt;br/&gt;&lt;b&gt;CLAS Cache Update&lt;/b&gt;&lt;br/&gt;Compiled policy written to
Cluster Local Actor Store.
Available cluster-wide." style="rounded=1;arcSize=8;fillColor=#E0F5EC;strokeColor=#0D7A5F;fontColor=#064F3C;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;html=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="590" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="17" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;strokeColor=#0D7A5F;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#0D7A5F;fontStyle=1;rounded=1;" edge="1" source="14" target="16" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="18" value="&lt;b&gt;STEP 5&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Storage Pod Cache&lt;/b&gt;&lt;br/&gt;Per-node Storage Pod receives
updated ruleset from CLAS.
Local cache refreshed." style="rounded=1;arcSize=8;fillColor=#FEF0DA;strokeColor=#9B5E0C;fontColor=#6B3D06;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;html=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="760" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="19" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;strokeColor=#9B5E0C;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#9B5E0C;fontStyle=1;rounded=1;" edge="1" source="16" target="18" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="20" value="&lt;b&gt;STEP 6&lt;/b&gt;&lt;br/&gt;&lt;b&gt;C-VEN Reads Policy&lt;/b&gt;&lt;br/&gt;C-VEN pulls compiled ruleset
from local Storage Pod.
No PCE contact needed (CLAS)." style="rounded=1;arcSize=8;fillColor=#E3EFFC;strokeColor=#1A66B5;fontColor=#0C3F75;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;html=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="930" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;strokeColor=#1A66B5;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#1A66B5;fontStyle=1;rounded=1;" edge="1" source="18" target="20" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="22" value="&lt;b&gt;STEP 7&lt;/b&gt;&lt;br/&gt;&lt;b&gt;iptables Programmed&lt;/b&gt;&lt;br/&gt;C-VEN translates ruleset
into iptables rules on host.
ILLUMIO_* chains active." style="rounded=1;arcSize=8;fillColor=#E3EFFC;strokeColor=#1A66B5;fontColor=#0C3F75;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;html=1;" vertex="1" parent="1">

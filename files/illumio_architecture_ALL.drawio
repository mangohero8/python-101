        <mxCell id="23" value="" style="edgeStyle=orthogonalEdgeStyle;dashed=1;dashPattern=8 4;strokeWidth=1.5;strokeColor=#0D7A5F;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#0D7A5F;fontStyle=1;rounded=1;" edge="1" source="20" target="21" parent="19">

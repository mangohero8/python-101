        <mxCell id="19" value="Kubernetes / OpenShift Cluster  —  Registered in PCE as container cluster object" style="swimlane;startSize=35;fillColor=#E0F5EC;strokeColor=#0D7A5F;fontColor=#064F3C;fontStyle=1;fontSize=13;fontFamily=Arial;strokeWidth=2;rounded=1;arcSize=2;" vertex="1" parent="1">

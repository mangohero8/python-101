        </mxCell>
        <mxCell id="20" value="🔗 Kubelink
Deployment · 1 per cluster
Watches K8s API for pod/svc events
Syncs pod metadata to PCE inventory
Handles label mapping config" style="rounded=1;arcSize=5;fillColor=#E0F5EC;strokeColor=#0D7A5F;fontColor=#064F3C;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="19">
          <mxGeometry x="15" y="50" width="230" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="⚡ CLAS Cache
Cluster Local Actor Store
Local compiled policy store
C-VEN reads from here not PCE
Core for K8s 5.0.0+" style="rounded=1;arcSize=5;fillColor=#E0F5EC;strokeColor=#0D7A5F;fontColor=#064F3C;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="19">

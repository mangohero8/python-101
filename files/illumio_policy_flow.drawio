        </mxCell>
        <mxCell id="29" value="✅ ACCEPT
pd=1 Allowed

Flow permitted.
Visible in Explorer
and Splunk as Allowed." style="rounded=1;arcSize=5;fillColor=#E4F5E2;strokeColor=#2E7D32;fontColor=#1B4D1D;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="800" y="280" width="220" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="30" value="YES — rule match" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;strokeColor=#2E7D32;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#2E7D32;fontStyle=1;rounded=1;" edge="1" source="27" target="29" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="Enforcement
Mode?" style="rhombus;fillColor=#F5F2EC;strokeColor=#6B6860;fontColor=#3F3E3A;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;" vertex="1" parent="1">

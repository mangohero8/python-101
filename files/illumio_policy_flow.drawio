        </mxCell>
        <mxCell id="24" value="📦 Pod Sends Packet" style="ellipse;fillColor=#E3EFFC;strokeColor=#1A66B5;fontColor=#0C3F75;fontSize=12;fontFamily=Arial;fontStyle=1;align=center;strokeWidth=2;" vertex="1" parent="1">

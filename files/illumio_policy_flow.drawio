        <mxCell id="21" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;strokeColor=#1A66B5;endArrow=block;endFill=1;fontFamily=Arial;fontSize=10;fontColor=#1A66B5;fontStyle=1;rounded=1;" edge="1" source="18" target="20" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="22" value="&lt;b&gt;STEP 7&lt;/b&gt;&lt;br/&gt;&lt;b&gt;iptables Programmed&lt;/b&gt;&lt;br/&gt;C-VEN translates ruleset
into iptables rules on host.
ILLUMIO_* chains active." style="rounded=1;arcSize=8;fillColor=#E3EFFC;strokeColor=#1A66B5;fontColor=#0C3F75;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;whiteSpace=wrap;strokeWidth=2;html=1;" vertex="1" parent="1">
